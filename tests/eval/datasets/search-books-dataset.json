{
  "eval_cases": [
    {
      "eval_case_id": "search_books_expected_flow",
      "prompt": {
        "role": "user",
        "parts": [
          {
            "text": "Search for fantasy books"
          }
        ]
      },
      "expected_tool_calls": [
        {
          "name": "get_user_library"
        },
        {
          "name": "find_books_by_context",
          "args": {
            "user_prompt": "fantasy books",
            "library_summary": "A collection of fantasy novels."
          }
        }
      ],
      "reference": {
        "response": {
          "role": "model",
          "parts": [
            {
              "text": "{\n  \"component\": \"List\",\n  \"status\": \"success\",\n  \"items\": [\n    {\n      \"title\": \"The Way of Kings\",\n      \"author\": \"Brandon Sanderson\",\n      \"genre\": \"Epic Fantasy\",\n      \"description\": \"An epic fantasy novel...\"\n    }\n  ]\n}"
            }
          ]
        }
      }
    },
