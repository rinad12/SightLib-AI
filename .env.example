# PostgreSQL connection - tables are created automatically on backend startup
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_postgres_password
DB_NAME=gridshelf

# GCP project used for Vertex AI (Gemini). Must have billing + Vertex AI API enabled,
# and `gcloud auth application-default login` run once for local dev credentials.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP Secret Manager tokens for MCP servers (optional - only needed if you added your
# own auth in front of the MCP servers; not required for local dev)
GCP_SECRET_MANAGER_DB_TOKEN=your_db_mcp_auth_token_here
GCP_SECRET_MANAGER_SEARCH_TOKEN=your_web_search_mcp_auth_token_here

# Google Books API key (unauthenticated requests hit a very low quota)
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# Google Sign-In (OAuth Client ID, not secret - from GCP Console > APIs & Services > Credentials)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com

# Signs the login session cookie - set to a long random string in any real deployment
SESSION_SECRET_KEY=change_me_to_a_random_secret

# Demo-only escape hatch: when true, adds a "Try without signing in" guest button (no Google
# account needed) instead of requiring Google Sign-In. Each guest gets a fresh, isolated,
# empty library. Meant to be turned on temporarily (e.g. to record a demo video without
# showing a real login) and back off afterwards.
# DEMO_MODE=true

# Cookie behavior for cross-origin frontend/backend deployments. Leave unset for local
# dev (frontend is proxied same-origin, see frontend/vite.config.js). If frontend and
# backend are deployed on different domains in production, set:
#   SESSION_COOKIE_SAMESITE=none
#   SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_SECURE=false
